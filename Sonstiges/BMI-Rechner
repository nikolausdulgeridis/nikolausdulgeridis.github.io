<SCRIPT LANGUAGE="JavaScript">
if (0) document.write("");

function berechne(f)
{
 if (0) alert(f.gewicht.value);
 var gewicht = parseInt(f.gewicht.value*1000)/1000;
 var groesse = parseInt(f.groesse.value*1000)/1000;
 groesse=groesse/100;
 if (groesse==0 || gewicht==0) return;
 var bmi=gewicht/(groesse*groesse);
 bmi=parseInt(bmi*100)/100;
 f.bmiresult.value=bmi;

 var gew;
 document.forms[1].bmiresultlist.value ="";
 for (gew = gewicht-8 ; gew < (gewicht+8) ; gew+=1) 
  {
   bmi=gew/(groesse*groesse);
   bmi=parseInt(bmi*10)/10;
   if (0) if (gew==gewicht) f.bmiresultlist.value += "n";;
   document.forms[1].bmiresultlist.value += "" + gew + "kg_"+ groesse + "m_" + bmi + " ";
  }
}
</SCRIPT>
